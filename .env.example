LLM_API_KEY=sk-your-deepseek-api-key

# Antwortmodell — Default: deepseek-v4-pro
LLM_MODEL=deepseek-v4-pro

# Extraktionsmodell (pro Chunk, Indexing) — Default: deepseek-v4-flash (schneller/billiger)
LLM_EXTRACTION_MODEL=deepseek-v4-flash

# Optional: Base-URL überschreiben — Default: https://api.deepseek.com
# Beliebige OpenAI-kompatible Endpoints werden unterstützt.
LLM_BASE_URL=

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password123
NEO4J_DATABASE=neo4j

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

CHUNK_SPLIT_LENGTH=10
CHUNK_SPLIT_OVERLAP=2
QUERY_TOP_K=5
GRAPH_HOPS=2
GRAPH_LIMIT=8
MAX_CONTEXT_CHARS=6000
ENTITY_MAX_TOKENS=800

# Hält die Antwort knapp genug für ≤15s Gesamtbudget mit V4 Pro non-thinking
# (~60 Zeichen/s). 500 Tokens ≈ 2000 Zeichen, in der Praxis ~7-11s.
ANSWER_MAX_TOKENS=500

# Hartes Timeout (Sekunden) NUR für den Antwort-LLM-Call. Plus ~4s Headroom
# für die Query-seitige Entity-Extraktion = 15s Gesamtbudget.
ANSWER_TIMEOUT_SECONDS=11

# Parallele LLM-Calls pro Indexing-Lauf (Entity-Extraktion). Default: 10
EXTRACTION_CONCURRENCY=10
