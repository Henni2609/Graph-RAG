HF_API_TOKEN=hf_your_token
HF_ENDPOINT_URL=https://your-endpoint.endpoints.huggingface.cloud

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password123
NEO4J_DATABASE=neo4j

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
GENERATION_MODEL=google/gemma-4-31b-it
ENTITY_EXTRACTION_MODEL=google/gemma-4-31b-it

CHUNK_SPLIT_LENGTH=10
CHUNK_SPLIT_OVERLAP=2
QUERY_TOP_K=5
GRAPH_HOPS=2
GRAPH_LIMIT=8
MAX_CONTEXT_CHARS=6000
ENTITY_MAX_TOKENS=800
ANSWER_MAX_TOKENS=1500
